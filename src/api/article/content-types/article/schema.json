{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": true
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "place",
        "people",
        "story",
        "guide"
      ]
    },
    "primary_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    },
    "city": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::city.city"
    },
    "region": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::region.region"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author"
    },
    "map_location": {
      "type": "component",
      "component": "shared.map_location",
      "repeatable": false
    },
    "contact_info": {
      "type": "component",
      "component": "shared.contact_info",
      "repeatable": false
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "content_blocks": {
      "type": "dynamiczone",
      "components": [
        "blocks.rich_text",
        "blocks.quote",
        "blocks.cta",
        "shared.gallery",
        "blocks.image",
        "blocks.gallery",
        "blocks.embed",
        "blocks.container"
      ],
      "required": false
    },
    "is_hogo_certified": {
      "type": "boolean"
    },
    "is_map_visible": {
      "type": "boolean"
    },
    "submission_source": {
      "type": "enumeration",
      "enum": [
        "editorial",
        "branded",
        "user",
        "curator"
      ]
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article"
    },
    "ExplodeArticles": {
      "type": "boolean"
    },
    "subtitle": {
      "type": "text"
    }
  }
}
